{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "An event containing photos.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique event ID" },
        "name": { "type": "string", "description": "Name of the event" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "createdBy": { "type": "string", "description": "User ID of the creator" },
        "location": { "type": "string", "description": "Optional location" }
      },
      "required": ["id", "name", "createdAt", "createdBy"]
    },
    "Photo": {
      "title": "Photo",
      "description": "A photo uploaded to an event.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique photo ID" },
        "eventId": { "type": "string", "description": "ID of the event this photo belongs to" },
        "url": { "type": "string", "description": "Base64 or URL of the photo" },
        "caption": { "type": "string", "description": "Optional caption for the photo" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Optional tags for the photo" },
        "uploadedAt": { "type": "string", "format": "date-time", "description": "Upload timestamp" },
        "uploadedBy": { "type": "string", "description": "User ID of the photographer" },
        "likes": { "type": "number", "description": "Number of likes" },
        "comments": { "type": "number", "description": "Number of comments" }
      },
      "required": ["id", "eventId", "url", "uploadedAt", "uploadedBy"]
    },
    "Activity": {
      "title": "Activity",
      "description": "User activity log.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "eventId": { "type": "string" },
        "photoId": { "type": "string" }
      },
      "required": ["userId", "type", "description", "timestamp"]
    },
    "UserStats": {
      "title": "User Stats",
      "description": "Aggregated stats for a user.",
      "type": "object",
      "properties": {
        "totalDownloads": { "type": "number" },
        "totalAiMatches": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Stores event details."
    },
    "/events/{eventId}/photos/{photoId}": {
      "schema": "Photo",
      "description": "Stores photos for a specific event."
    },
    "/activity/{activityId}": {
      "schema": "Activity",
      "description": "Stores user activity logs."
    },
    "/user_stats/{userId}": {
      "schema": "UserStats",
      "description": "Stores user statistics."
    }
  }
}
