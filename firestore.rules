service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isEventCreator(eventId) {
      return isAuthenticated() && get(/databases/$(database)/documents/events/$(eventId)).data.createdBy == request.auth.uid;
    }

    // Events
    match /events/{eventId} {
      allow read: if true; // Publicly readable for gallery access
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.createdBy);

      // Photos subcollection
      match /photos/{photoId} {
        allow read: if true;
        allow create: if isAuthenticated();
        // Allow delete if photographer OR event creator
        allow delete: if isOwner(resource.data.uploadedBy) || isEventCreator(eventId);
        allow update: if isOwner(resource.data.uploadedBy);
      }
    }
    
    // Users collection for profiles
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}
